# Realistic minimal mtuirc fixture used by tests/test_config.py to exercise
# the INI parser end-to-end (multiple sections, multiple value types).
[mtui]
location = nuremberg
connection_timeout = 450
user = qauser
chdir_to_template_dir = true

[openqa]
openqa = https://openqa.example.com
distri = sle
install_logfile = update_install-zypper.log

[qem_dashboard]
api = https://dashboard.example.com/api

[gitea]
token = ghp_fixture_token_for_tests

[connection]
ssh_strict_host_key_checking = warn

[url]
bugzilla = https://bugzilla.example.com
testreports = https://qam.example.com/testreports
