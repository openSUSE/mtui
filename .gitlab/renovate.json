{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableMajorUpdates"
  ],
  "enabledManagers": [
    "cargo",
    "gitlabci",
    "pre-commit"
  ],
  "pre-commit": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* * * * 1,4"]
  },
  "schedule": [
    "* * * * 1,4"
  ],
  "prHourlyLimit": 1,
  "prConcurrentLimit": 3,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "dependency updates",
      "automerge": false
    }
  ]
}
