{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableMajorUpdates"
  ],
  "timezone": "Europe/Prague",
  "enabledManagers": [
    "cargo",
    "gitlabci"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* * * * 1,4"]
  },
  "schedule": [
    "* * * * 1,4"
  ],
  "prHourlyLimit": 1,
  "prConcurrentLimit": 3,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "dependency updates",
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  },
  "osvVulnerabilityAlerts": true
}
